# ── Ink Timodal 設定ファイル ──────────────────────
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env

# DuckDNSで取得したサブドメイン名（例: ink-timodal）
DOMAIN=your-subdomain.duckdns.org

# DuckDNSのトークン（https://www.duckdns.org でログイン後に確認）
DUCKDNS_TOKEN=your-duckdns-token

# Let's Encrypt用メールアドレス（証明書の期限通知に使用）
EMAIL=your@email.com
